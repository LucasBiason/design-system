{
  "name": "design-system-svelte",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "storybook": "storybook dev -p 6008",
    "build-storybook": "storybook build",
    "test-storybook": "test-storybook --url http://127.0.0.1:6008",
    "test-storybook:component": "test-storybook --url http://127.0.0.1:6008",
    "test-storybook:ci": "concurrently -k -s first -n \"SB,TEST\" -c \"magenta,blue\" \"npx http-server storybook-static --port 6008 --silent\" \"npx wait-on tcp:6008 && npm run test-storybook\"",
    "chromatic": "npx chromatic",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@tanstack/svelte-virtual": "^3.13.28",
    "@tanstack/table-core": "^8.21.3",
    "@tanstack/virtual-core": "^3.17.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "echarts": "^6.1.0",
    "embla-carousel-autoplay": "^8.6.0",
    "lucide": "^1.8.0",
    "lucide-svelte": "^0.577.0",
    "quill": "^2.0.3",
    "svelte": "^5.55.4",
    "tailwind-merge": "^3.5.0",
    "tslib": "^2.8.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.8.0",
    "@storybook/addon-a11y": "^10.4.0",
    "@storybook/addon-docs": "^10.4.0",
    "@storybook/addon-mcp": "^0.6.0",
    "@storybook/addon-onboarding": "^10.4.0",
    "@storybook/addon-themes": "^10.4.0",
    "@storybook/addon-vitest": "^10.4.0",
    "@storybook/svelte-vite": "^10.4.0",
    "@storybook/test-runner": "^0.24.4",
    "@sveltejs/vite-plugin-svelte": "^5.1.1",
    "@tailwindcss/vite": "^4.2.4",
    "@tsconfig/svelte": "^5.0.8",
    "@types/node": "^24.12.2",
    "@vitest/browser-playwright": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "axe-playwright": "^2.2.2",
    "bits-ui": "^2.18.0",
    "concurrently": "^9.2.1",
    "embla-carousel-svelte": "^8.6.0",
    "eslint": "^9.39.4",
    "eslint-plugin-storybook": "^10.4.0",
    "formsnap": "^2.0.1",
    "http-server": "^14.1.1",
    "mode-watcher": "^1.1.0",
    "paneforge": "^1.0.2",
    "patch-package": "^8.0.1",
    "playwright": "^1.59.1",
    "storybook": "^10.4.0",
    "svelte-sonner": "^1.1.0",
    "sveltekit-superforms": "^2.30.1",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vaul-svelte": "^1.0.0-next.7",
    "vite": "^6.4.2",
    "vitest": "^4.1.5",
    "wait-on": "^9.0.5"
  },
  "eslintConfig": {
    "extends": [
