        "$description": "--border | oklch(0.922 0 0)"
      },
      "input": {
        "$type": "color",
        "$value": "#e5e5e5",
        "$description": "--input | oklch(0.922 0 0)"
      },
      "inputBackground": {
        "$type": "color",
        "$value": "#ffffff",
        "$description": "--input-background | hsl(0 0% 100%)"
      },
      "ring": {
        "$type": "color",
        "$value": "#a3a3a3",
        "$description": "--ring | oklch(0.708 0 0)"
