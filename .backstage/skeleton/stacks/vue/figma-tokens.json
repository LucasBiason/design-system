        "primaryForeground": {
          "$type": "color",
          "$value": "#fafafa",
          "$description": "--sidebar-primary-foreground | oklch(0.985 0 0)"
        },
        "accent": {
          "$type": "color",
          "$value": "#f5f5f5",
          "$description": "--sidebar-accent | oklch(0.97 0 0)"
        },
        "accentForeground": {
          "$type": "color",
          "$value": "#27272a",
          "$description": "--sidebar-accent-foreground | oklch(0.205 0 0)"
