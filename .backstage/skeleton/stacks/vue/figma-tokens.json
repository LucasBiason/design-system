      },
      "muted": {
        "$type": "color",
        "$value": "#404040",
        "$description": "--muted | oklch(0.269 0 0)"
      },
      "mutedForeground": {
        "$type": "color",
        "$value": "#a3a3a3",
        "$description": "--muted-foreground | oklch(0.708 0 0)"
      },
      "accent": {
        "$type": "color",
