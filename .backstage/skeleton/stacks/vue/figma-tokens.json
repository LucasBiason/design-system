{
  "$metadata": {
    "tokenSetOrder": ["global", "light", "dark"]
  },
  "global": {
    "$description": "Tokens independentes de tema (tipografia, espaçamento, raio, sombra, transição, z-index)",

    "font": {
      "family": {
        "sans": {
          "$type": "fontFamily",
          "$value": ["Inter", "sans-serif"],
          "$description": "--font-family"
        }
      },
      "size": {
        "base": {
          "$type": "dimension",
          "$value": "16px",
          "$description": "--font-size"
        },
        "h1": {
          "$type": "dimension",
          "$value": "48px",
          "$description": "--text-h1"
        },
        "h2": {
          "$type": "dimension",
          "$value": "30px",
          "$description": "--text-h2"
        },
        "h3": {
          "$type": "dimension",
          "$value": "20px",
          "$description": "--text-h3"
        },
        "h4": {
          "$type": "dimension",
          "$value": "16px",
          "$description": "--text-h4"
        },
        "p": {
          "$type": "dimension",
          "$value": "14px",
          "$description": "--text-p"
        },
        "label": {
          "$type": "dimension",
          "$value": "12px",
          "$description": "--text-label"
        }
      },
      "weight": {
        "regular": {
          "$type": "fontWeight",
          "$value": 400,
          "$description": "--font-weight-regular"
        },
        "medium": {
          "$type": "fontWeight",
          "$value": 500,
          "$description": "--font-weight-medium"
        },
        "semibold": {
          "$type": "fontWeight",
          "$value": 600,
          "$description": "--font-weight-semi-bold"
        },
        "extrabold": {
          "$type": "fontWeight",
          "$value": 800,
          "$description": "--font-weight-extra-bold"
        }
      },
      "lineHeight": {
        "tight": {
          "$type": "number",
          "$value": 1.2,
          "$description": "--line-height-tight"
        },
        "normal": {
          "$type": "number",
          "$value": 1.5,
          "$description": "--line-height-normal"
        },
        "relaxed": {
          "$type": "number",
          "$value": 1.75,
          "$description": "--line-height-relaxed"
        },
        "loose": {
          "$type": "number",
          "$value": 2,
          "$description": "--line-height-loose"
        }
      },
      "letterSpacing": {
        "tight": {
          "$type": "dimension",
          "$value": "-0.02em",
          "$description": "--letter-spacing-tight"
        },
        "normal": {
          "$type": "dimension",
          "$value": "0em",
          "$description": "--letter-spacing-normal"
        },
        "wide": {
          "$type": "dimension",
          "$value": "0.02em",
          "$description": "--letter-spacing-wide"
        }
      }
    },

    "typography": {
      "h1": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.h1}",
          "fontWeight": "{global.font.weight.extrabold}",
          "lineHeight": "{global.font.lineHeight.tight}",
          "letterSpacing": "{global.font.letterSpacing.tight}"
        }
      },
      "h2": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.h2}",
          "fontWeight": "{global.font.weight.semibold}",
          "lineHeight": "{global.font.lineHeight.tight}",
          "letterSpacing": "{global.font.letterSpacing.normal}"
        }
      },
      "h3": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.h3}",
          "fontWeight": "{global.font.weight.semibold}",
          "lineHeight": "{global.font.lineHeight.normal}",
          "letterSpacing": "{global.font.letterSpacing.normal}"
        }
      },
      "h4": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.h4}",
          "fontWeight": "{global.font.weight.medium}",
          "lineHeight": "{global.font.lineHeight.normal}",
          "letterSpacing": "{global.font.letterSpacing.normal}"
        }
      },
      "body": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.p}",
          "fontWeight": "{global.font.weight.regular}",
          "lineHeight": "{global.font.lineHeight.normal}",
          "letterSpacing": "{global.font.letterSpacing.normal}"
        }
      },
      "label": {
        "$type": "typography",
        "$value": {
          "fontFamily": "{global.font.family.sans}",
          "fontSize": "{global.font.size.label}",
          "fontWeight": "{global.font.weight.medium}",
          "lineHeight": "{global.font.lineHeight.normal}",
          "letterSpacing": "{global.font.letterSpacing.wide}"
        }
      }
    },

    "radius": {
      "sm": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "--radius: 0.625rem (10px); sm = radius - 2px ≈ 8px"
      },
      "md": {
        "$type": "dimension",
        "$value": "10px",
        "$description": "--radius: 0.625rem"
      },
      "button": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "--radius-button"
      },
      "card": {
        "$type": "dimension",
        "$value": "8px",
        "$description": "--radius-card"
      }
    },

    "shadow": {
      "sm": {
        "$type": "shadow",
        "$value": {
          "offsetX": "0px",
          "offsetY": "1px",
          "blur": "2px",
          "spread": "0px",
          "color": "rgba(0,0,0,0.10)"
        },
        "$description": "--elevation-sm"
      },
      "md": {
        "$type": "shadow",
        "$value": [
          {
            "offsetX": "0px",
            "offsetY": "4px",
            "blur": "6px",
            "spread": "-1px",
            "color": "rgba(0,0,0,0.10)"
          },
          {
            "offsetX": "0px",
            "offsetY": "2px",
            "blur": "4px",
            "spread": "-1px",
            "color": "rgba(0,0,0,0.06)"
          }
        ],
        "$description": "--elevation-md"
      },
      "lg": {
        "$type": "shadow",
        "$value": [
          {
            "offsetX": "0px",
            "offsetY": "10px",
            "blur": "15px",
            "spread": "-3px",
            "color": "rgba(0,0,0,0.10)"
          },
          {
            "offsetX": "0px",
            "offsetY": "4px",
            "blur": "6px",
            "spread": "-2px",
            "color": "rgba(0,0,0,0.05)"
          }
        ],
        "$description": "--elevation-lg"
      },
      "xl": {
        "$type": "shadow",
        "$value": [
          {
            "offsetX": "0px",
            "offsetY": "20px",
            "blur": "25px",
            "spread": "-5px",
            "color": "rgba(0,0,0,0.10)"
          },
          {
            "offsetX": "0px",
            "offsetY": "10px",
            "blur": "10px",
            "spread": "-5px",
            "color": "rgba(0,0,0,0.04)"
          }
        ],
        "$description": "--elevation-xl"
      }
    },

    "transition": {
      "duration": {
        "fast": {
          "$type": "duration",
          "$value": "150ms",
          "$description": "--transition-fast"
        },
        "normal": {
          "$type": "duration",
          "$value": "300ms",
          "$description": "--transition-normal"
        },
        "slow": {
          "$type": "duration",
          "$value": "500ms",
          "$description": "--transition-slow"
        }
      },
      "easing": {
        "default": {
          "$type": "cubicBezier",
          "$value": [0.4, 0, 0.2, 1],
          "$description": "--transition-timing"
        }
      }
    },

    "zIndex": {
      "dropdown": {
        "$type": "number",
        "$value": 1000,
        "$description": "--z-dropdown"
      },
      "sticky": {
        "$type": "number",
        "$value": 1020,
        "$description": "--z-sticky"
      },
      "fixed": {
        "$type": "number",
        "$value": 1030,
        "$description": "--z-fixed"
      },
      "modalBackdrop": {
        "$type": "number",
        "$value": 1040,
        "$description": "--z-modal-backdrop"
      },
      "modal": {
        "$type": "number",
        "$value": 1050,
        "$description": "--z-modal"
      },
      "popover": {
        "$type": "number",
        "$value": 1060,
        "$description": "--z-popover"
      },
      "tooltip": {
        "$type": "number",
        "$value": 1070,
        "$description": "--z-tooltip"
      }
    },

    "ring": {
      "offsetWidth": {
        "$type": "dimension",
        "$value": "2px",
        "$description": "--ring-offset-width"
      }
    }
  },

  "light": {
