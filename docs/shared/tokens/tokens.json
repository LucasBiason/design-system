{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Source of truth for all design tokens. CSS custom properties are generated from this file.",

  "color": {
    "base": {
      "white":       { "$value": "0 0% 100%",   "$type": "color", "$description": "Pure white (HSL)" },
      "black":       { "$value": "0 0% 0%",     "$type": "color" },
      "neutral-950": { "$value": "0 0% 4%",     "$type": "color" },
      "neutral-900": { "$value": "0 0% 9%",     "$type": "color" },
      "neutral-800": { "$value": "0 0% 15%",    "$type": "color" },
      "neutral-700": { "$value": "0 0% 25%",    "$type": "color" },
      "neutral-500": { "$value": "0 0% 45%",    "$type": "color" },
      "neutral-400": { "$value": "0 0% 63.9%",  "$type": "color" },
      "neutral-200": { "$value": "0 0% 83%",    "$type": "color" },
      "neutral-100": { "$value": "0 0% 90%",    "$type": "color" },
      "neutral-50":  { "$value": "0 0% 96%",    "$type": "color" },
      "neutral-25":  { "$value": "0 0% 98%",    "$type": "color" }
    },
    "semantic": {
      "background":          { "$value": "{color.base.white}",      "$type": "color" },
      "foreground":          { "$value": "{color.base.neutral-950}", "$type": "color" },
      "primary":             { "$value": "{color.base.neutral-900}", "$type": "color" },
      "primary-foreground":  { "$value": "{color.base.neutral-25}",  "$type": "color" },
      "secondary":           { "$value": "{color.base.neutral-50}",  "$type": "color" },
      "secondary-foreground":{ "$value": "{color.base.neutral-950}", "$type": "color" },
      "muted":               { "$value": "{color.base.neutral-50}",  "$type": "color" },
      "muted-foreground":    { "$value": "0 0% 40%",          "$type": "color" },
      "accent":              { "$value": "{color.base.neutral-50}",  "$type": "color" },
      "accent-foreground":   { "$value": "{color.base.neutral-900}", "$type": "color" },
      "border":              { "$value": "{color.base.neutral-100}", "$type": "color" },
      "input":               { "$value": "{color.base.neutral-100}", "$type": "color" },
      "ring":                { "$value": "{color.base.neutral-500}", "$type": "color" },
      "destructive":         { "$value": "0 74% 42%",    "$type": "color" },
      "destructive-foreground": { "$value": "{color.base.white}", "$type": "color" },
      "success":             { "$value": "142 85% 22%",  "$type": "color" },
      "success-foreground":  { "$value": "{color.base.white}", "$type": "color" },
      "warning":             { "$value": "31 92% 32%",   "$type": "color" },
      "warning-foreground":  { "$value": "{color.base.white}", "$type": "color" },
      "info":                { "$value": "221 83% 43%",  "$type": "color" },
      "info-foreground":     { "$value": "{color.base.white}", "$type": "color" }
    },
    "chart": {
      "1": { "$value": "199 89% 65%", "$type": "color" },
      "2": { "$value": "200 100% 50%", "$type": "color" },
      "3": { "$value": "201 98% 48%",  "$type": "color" },
      "4": { "$value": "201 88% 43%",  "$type": "color" },
      "5": { "$value": "210 71% 23%",  "$type": "color" }
    },
    "sidebar": {
      "background":          { "$value": "{color.base.neutral-25}",  "$type": "color" },
      "foreground":          { "$value": "{color.base.neutral-950}", "$type": "color" },
      "primary":             { "$value": "{color.base.neutral-900}", "$type": "color" },
      "primary-foreground":  { "$value": "{color.base.neutral-25}",  "$type": "color" },
      "accent":              { "$value": "{color.base.neutral-50}",  "$type": "color" },
      "accent-foreground":   { "$value": "{color.base.neutral-900}", "$type": "color" },
      "border":              { "$value": "{color.base.neutral-200}", "$type": "color" },
      "ring":                { "$value": "{color.base.neutral-500}", "$type": "color" }
    }
  },

  "typography": {
    "font-family":    { "$value": "'Inter', sans-serif", "$type": "fontFamily" },
    "font-size-base": { "$value": "16px", "$type": "dimension" },
    "size": {
      "h1":    { "$value": "48px", "$type": "dimension" },
      "h2":    { "$value": "30px", "$type": "dimension" },
      "h3":    { "$value": "20px", "$type": "dimension" },
      "h4":    { "$value": "16px", "$type": "dimension" },
      "p":     { "$value": "14px", "$type": "dimension" },
      "label": { "$value": "12px", "$type": "dimension" }
    },
    "weight": {
      "extra-bold": { "$value": "800", "$type": "fontWeight" },
      "semi-bold":  { "$value": "600", "$type": "fontWeight" },
      "medium":     { "$value": "500", "$type": "fontWeight" },
      "regular":    { "$value": "400", "$type": "fontWeight" }
    },
    "line-height": {
      "tight":   { "$value": "1.2",  "$type": "number" },
      "normal":  { "$value": "1.5",  "$type": "number" },
      "relaxed": { "$value": "1.75", "$type": "number" },
      "loose":   { "$value": "2",    "$type": "number" }
    },
    "letter-spacing": {
      "tight":  { "$value": "-0.02em", "$type": "dimension" },
      "normal": { "$value": "0em",     "$type": "dimension" },
      "wide":   { "$value": "0.02em",  "$type": "dimension" }
    }
  },

  "radius": {
    "base":   { "$value": "8px", "$type": "dimension" },
    "button": { "$value": "8px", "$type": "dimension" },
    "card":   { "$value": "8px", "$type": "dimension" }
  },

  "elevation": {
    "sm": { "$value": "0px 1px 2px 0px rgba(0,0,0,0.1)", "$type": "shadow" },
    "md": { "$value": "0px 4px 6px -1px rgba(0,0,0,0.1), 0px 2px 4px -1px rgba(0,0,0,0.06)", "$type": "shadow" },
    "lg": { "$value": "0px 10px 15px -3px rgba(0,0,0,0.1), 0px 4px 6px -2px rgba(0,0,0,0.05)", "$type": "shadow" },
    "xl": { "$value": "0px 20px 25px -5px rgba(0,0,0,0.1), 0px 10px 10px -5px rgba(0,0,0,0.04)", "$type": "shadow" }
  },

  "transition": {
    "fast":   { "$value": "150ms", "$type": "duration" },
    "normal": { "$value": "300ms", "$type": "duration" },
    "slow":   { "$value": "500ms", "$type": "duration" },
    "timing": { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" }
  },

  "z-index": {
    "dropdown":      { "$value": "1000", "$type": "number" },
    "sticky":        { "$value": "1020", "$type": "number" },
    "fixed":         { "$value": "1030", "$type": "number" },
    "modal-backdrop":{ "$value": "1040", "$type": "number" },
    "modal":         { "$value": "1050", "$type": "number" },
    "popover":       { "$value": "1060", "$type": "number" },
    "tooltip":       { "$value": "1070", "$type": "number" }
  }
}
